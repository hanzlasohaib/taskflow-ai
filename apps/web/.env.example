# TaskFlow Web — environment variables
# Copy to apps/web/.env.local and fill in real values. Never commit secrets.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Supabase PostgreSQL)
DATABASE_URL=
DIRECT_URL=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Resend
RESEND_API_KEY=
EMAIL_FROM=

# Google reCAPTCHA v3
RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Deepgram
DEEPGRAM_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Storage (sketch images)
BLOB_OR_STORAGE_BUCKET=sketches
