# TaskFlow Web — environment variables
# Copy to apps/web/.env.local and fill in real values. Never commit secrets.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Supabase PostgreSQL)
# Use the pooled connection string for DATABASE_URL (often port 6543 / pgBouncer).
# Use the direct connection string for DIRECT_URL (migrations; often port 5432 / db.<project>.supabase.co).
# Prefer appending sslmode=require. For pooler: ?pgbouncer=true&connection_limit=1&sslmode=require
DATABASE_URL=
DIRECT_URL=

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Resend
RESEND_API_KEY=
EMAIL_FROM="TaskFlow <onboarding@resend.dev>"

# Google reCAPTCHA v3
# Leave blank locally to skip captcha plugin; set both for production.
RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Deepgram (later phases)
DEEPGRAM_API_KEY=

# Supabase (realtime / storage)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Storage
# Avatars bucket (public read; server uploads with service role)
AVATARS_BUCKET=avatars
# Sketch images — later phases
BLOB_OR_STORAGE_BUCKET=sketches
